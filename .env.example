# Algo Trader v1 — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PASSWORD=choose_a_strong_password

# ── Telegram Alerts ───────────────────────────────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_token_from_botfather
TELEGRAM_CHAT_ID=your_numeric_chat_id
TELEGRAM_COOLDOWN_SECS=14400

# ── Bot Behaviour ─────────────────────────────────────────────────────────────
# BOT_MODE=shadow
# SCAN_INTERVAL_SECS=900
# FOCUS_SIZE=89

# ── Data Provider (M6) ────────────────────────────────────────────────────────
# DATA_PROVIDER=yfinance        # default
# DATA_PROVIDER=alpaca          # requires ALPACA_KEY + ALPACA_SECRET
ALPACA_KEY=
ALPACA_SECRET=

# ── Sentiment (M8) ───────────────────────────────────────────────────────────
# SENTIMENT_MODE=off            # off | confirm | block | ignore (default: off)
# SENTIMENT_PROVIDER=auto       # auto | yfinance_news | google_news | alphavantage
# SENTIMENT_THRESHOLD=0.15
# ALPHAVANTAGE_KEY=             # optional, for alphavantage sentiment provider

# ── Broker / Execution (M10–M12) ─────────────────────────────────────────────
# BROKER=paper                  # paper (default) | ibkr_paper | ibkr_live

# IBKR paper trading (M11):
# BROKER=ibkr_paper
# IBKR_HOST=127.0.0.1
# IBKR_PORT=4002
# IBKR_ACCOUNT=DUP623346

# IBKR live trading (M12) — ALL FOUR required or bot refuses to start:
# BROKER=ibkr_live
# IBKR_LIVE_ACCOUNT=<your_live_account_id>
# IBKR_LIVE_PORT=4001
# IBKR_LIVE_CONFIRMED=yes        # must be exactly 'yes' — explicit human confirmation

# ── Risk Limits (M10) ────────────────────────────────────────────────────────
# RISK_MAX_POSITION_PCT=2.0      # max % of portfolio per position (hard cap 2.0 in live)
# RISK_MAX_OPEN_POSITIONS=10
# RISK_PORTFOLIO_SIZE=100000
# RISK_ALLOW_DUPLICATES=false
