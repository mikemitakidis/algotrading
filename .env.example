# Algo Trader v1 — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PASSWORD=choose_a_strong_password

# ── Telegram Alerts ───────────────────────────────────────────────────────────
# Set TELEGRAM_ENABLED=true to activate alerts
# Leave false to run without alerts (bot still works)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_token_from_botfather
TELEGRAM_CHAT_ID=your_numeric_chat_id

# How long to suppress repeated alerts for same symbol+direction (seconds)
# Default: 14400 = 4 hours
TELEGRAM_COOLDOWN_SECS=14400

# ── Bot Behaviour (all optional — defaults shown) ─────────────────────────────
# BOT_MODE=shadow
# SCAN_INTERVAL_SECS=900
# RANK_INTERVAL_SECS=21600
# FOCUS_SIZE=150

# ── Reserved for future phases (not used in V1) ───────────────────────────────
# ALPACA_API_KEY=
# ALPACA_SECRET_KEY=
