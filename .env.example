# Algo Trader v1 — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PASSWORD=choose_a_strong_password

# ── Telegram Alerts ───────────────────────────────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_token_from_botfather
TELEGRAM_CHAT_ID=your_numeric_chat_id
TELEGRAM_COOLDOWN_SECS=3600

# ── Bot Behaviour ─────────────────────────────────────────────────────────────
# BOT_MODE=shadow
# SCAN_INTERVAL_SECS=900
# FOCUS_SIZE=89

# ── Data Provider (M6) ────────────────────────────────────────────────────────
# DATA_PROVIDER=yfinance        # default
# DATA_PROVIDER=alpaca          # requires ALPACA_KEY + ALPACA_SECRET
ALPACA_KEY=
ALPACA_SECRET=

# ── Sentiment (M8) ───────────────────────────────────────────────────────────
# SENTIMENT_MODE=off            # off | confirm | block | ignore (default: off)
# SENTIMENT_PROVIDER=auto       # auto | yfinance_news | google_news | alphavantage
# SENTIMENT_THRESHOLD=0.15
# ALPHAVANTAGE_KEY=             # optional, for alphavantage sentiment provider

# ── Broker / Execution (M10–M12) ─────────────────────────────────────────────
# BROKER=paper                  # paper (default) | ibkr_paper | ibkr_live

# IBKR paper trading (M11):
# BROKER=ibkr_paper
# IBKR_HOST=127.0.0.1
# IBKR_PORT=4002
# IBKR_ACCOUNT=DUP623346

# IBKR live trading (M12) — ALL FOUR required or bot refuses to start:
# BROKER=ibkr_live
# IBKR_LIVE_ACCOUNT=<your_live_account_id>
# IBKR_LIVE_PORT=4001
# IBKR_LIVE_CONFIRMED=yes        # must be exactly 'yes' — explicit human confirmation

# ── Risk Limits (M10) ────────────────────────────────────────────────────────
# RISK_MAX_POSITION_PCT=2.0      # max % of portfolio per position (hard cap 2.0 in live)
# RISK_MAX_OPEN_POSITIONS=10
# RISK_PORTFOLIO_SIZE=100000
# RISK_ALLOW_DUPLICATES=false

# ── M15.1 Gateway Watchdog (single in-process timed prober) ──────────────────
# All keys below have safe defaults. Override only if needed.
# GATEWAY_WATCHDOG_ENABLED=true             # master on/off
# GATEWAY_WATCHDOG_MODE=alert_only          # alert_only | systemd_restart
                                            #   systemd_restart is RECOGNISED but INERT in M15.1
                                            #   (logged as restart_eligible_but_disabled_m15_1; no real restart)
# GATEWAY_WATCHDOG_INTERVAL_SEC=60          # probe cadence
# GATEWAY_WATCHDOG_API_TIMEOUT_SEC=5        # IB API probe hard timeout
# GATEWAY_WATCHDOG_ALERT_COOLDOWN_MIN=15    # Telegram dedup window
# GATEWAY_WATCHDOG_MIN_RESTART_INTERVAL_MIN=30  # M15.2 cooldown gate (already enforced in policy)
# GATEWAY_WATCHDOG_MAX_RESTARTS_PER_HOUR=2      # M15.2 rolling rate cap (already enforced in policy)
# GATEWAY_WATCHDOG_FAILURES_TO_DOWN=2        # consecutive failures to leave api_up_healthy
# GATEWAY_WATCHDOG_DEGRADED_WINDOW_MIN=10    # rolling window for degraded flag
# GATEWAY_WATCHDOG_DEGRADED_FAIL_RATE=0.30   # failure rate threshold for degraded flag
# GATEWAY_WATCHDOG_MANUAL_ACTION_AFTER_MIN=5 # stuck in tcp_up_api_down -> manual_action_required
# IBKR_SYSTEMD_UNIT=ibgateway               # systemd unit name (read-only is-active probe)

# ── M15.2 Health Endpoint + Heartbeat (external monitoring) ──────────────────
# HEARTBEAT_INTERVAL_SEC=45              # heartbeat write cadence, independent of scan_interval
# HEARTBEAT_STALE_SEC=90                 # /api/health flips to critical/503 above this
# SCAN_STALE_MULTIPLIER=3                # scan_completed_age > scan_interval * multiplier -> critical
# HEALTH_ENDPOINT_AUTH_TOKEN=            # optional bearer token. Empty = unauth + minimal payload.
                                         # Set to a long random secret for production.
                                         # Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# HEARTBEAT_FILE_PATH=                   # absolute path override; empty = <repo>/data/heartbeat.json
