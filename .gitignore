# Secrets — never committed
.env

# Runtime data — stays on server
logs/
data/
*.db
*.log

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
.venv/
*.egg-info/
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo

# M15 hardening — secrets and backup hygiene
.github_token
*.token
.env.bak*
*_backup.py
*.bak

# M15.2 heartbeat (atomic-rename JSON written every 45s by main.py)
data/heartbeat.json
data/heartbeat.json.tmp.*
data/.hb_probe_*

# M16 historical-data engine (RUNTIME ARTIFACTS — never committed).
# The blanket `data/` rule above already covers these; entries here
# are explicit so the intent is greppable.
data/historical.db
data/historical.db-*
data/historical/
data/*.parquet
data/*.parquet.tmp.*
data/.historical_refresh.lock
data/.historical_refresh.lock.*
recovery_inputs/
recovery_extracted/
data/ml/
data/paper/
