.vscode/
.idea/
*.swp
*.swo

# M15 hardening — secrets and backup hygiene
.github_token
*.token
.env.bak*
*_backup.py
*.bak

# M15.2 heartbeat (atomic-rename JSON written every 45s by main.py)
data/heartbeat.json
data/heartbeat.json.tmp.*
data/.hb_probe_*
